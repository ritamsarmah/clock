<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Clock</title>
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
</head>
<body>
    <h1>Clock</h1>

    <div id="apps">
        {{range .Apps}}
        <button hx-post="/start?app={{.}}" hx-swap="none">{{.}}</button>
        <br/>
        {{end}}
    </div>

    <br/>
    <button hx-post="/stop" hx-swap="none">Stop Current App</button>
</body>
</html>
